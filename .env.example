# Copy to .env and fill with your Supabase Postgres connection.
# Use the direct connection (port 5432) or the session pooler from the
# Supabase dashboard → Project Settings → Database. NEVER commit the real .env.

# JDBC URL. Example (direct connection):
#   jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
GRIP_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres

# A role that can read contacts/status_events. The service bypasses RLS and
# scopes every query by user_id in code.
GRIP_DB_USER=postgres
GRIP_DB_PASSWORD=

# Optional: override the daily reminder schedule (Spring cron, 6 fields).
# GRIP_REMINDERS_CRON=0 0 8 * * *
